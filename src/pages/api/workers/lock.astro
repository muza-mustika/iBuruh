export async function POST({ request, locals }) {
  const db = locals.runtime?.env?.DB || locals.env?.DB;
  if (!db) {
    return new Response('Database not available', { status: 500 });
  }

  try {
    const body = await request.json();
    const { session_id, filter_hash, filter_params, worker_ids } = body;

    if (!session_id || !filter_hash || !worker_ids || !Array.isArray(worker_ids)) {
      return new Response('Missing required fields', { status: 400 });
    }

    // First, release any existing locks for this session
    await db.prepare(
      'DELETE FROM temporary_bookings WHERE session_id = ?'
    ).bind(session_id).run();

    // Set expiration time (15 minutes from now)
    const expiresAt = new Date(Date.now() + 15 * 60 * 1000).toISOString();

    // Lock each worker
    for (const workerId of worker_ids) {
      try {
        await db.prepare(
          `INSERT INTO temporary_bookings (worker_id, user_id, session_id, filter_hash, filter_params, expires_at)
           VALUES (?, ?, ?, ?, ?, ?)`
        ).bind(
          workerId,
          session_id, // Using session_id as user_id for simplicity
          session_id,
          filter_hash,
          JSON.stringify(filter_params),
          expiresAt
        ).run();
      } catch (error) {
        // If worker is already locked by another session, skip it
        console.log(`Worker ${workerId} already locked, skipping`);
      }
    }

    // Get the successfully locked workers
    const lockedWorkers = await db.prepare(
      'SELECT worker_id FROM temporary_bookings WHERE session_id = ?'
    ).bind(session_id).all();

    return new Response(JSON.stringify({ 
      success: true, 
      locked_workers: lockedWorkers.results.map(w => w.worker_id),
      expires_at: expiresAt 
    }), {
      headers: { 'Content-Type': 'application/json' },
    });
  } catch (error) {
    console.error('Error locking workers:', error);
    return new Response('Error locking workers', { status: 500 });
  }
}